# LLM provider: ollama | gemini | openai
LLM_PROVIDER=ollama

# Ollama (local, free) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_API_KEY=ollama

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCkhMnL6bpZX857KaepLNusGtNrBxUzdHM
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# PostgreSQL + pgvector (matches docker-compose.yml)
# If 5432 is already used by a local Postgres, change this (e.g. 5433)
DB_HOST=localhost
# 5432 is taken by a native Postgres on this machine; use 5433 for the container
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_knowledge

PORT=3000
